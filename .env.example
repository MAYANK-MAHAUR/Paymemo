VITE_MORPH_CHAIN_ID=2910
VITE_MORPH_RPC_URL=https://rpc-hoodi.morph.network
VITE_MORPH_EXPLORER_URL=https://explorer-hoodi.morph.network

# ERC-20 contracts for live token transfers on Morph Hoodi.
# Native ETH works without a contract. USDC/WETH default to Morph's official Hoodi contracts in code.
VITE_MORPH_USDC_ADDRESS=0x1178341838B764dCfFA5BCEAb1d41443Fd71a227
VITE_MORPH_WETH_ADDRESS=0x5300000000000000000000000000000000000011

# BGB is first-class in the UI. Set this only if you have a real BGB contract deployed/available on Hoodi.
VITE_MORPH_BGB_ADDRESS=

# Supabase database adapter.
# Keep service role server-side only. Never expose it through VITE_* variables.
# Local development falls back to database/paymemo-dev-db.json when these are empty.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional public key for future RLS/anon browser flows. The current server adapter does not need it.
SUPABASE_ANON_KEY=
